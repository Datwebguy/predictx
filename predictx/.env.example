# ─── Shared ──────────────────────────────────────────────────────────────────
# Copy this to .env and fill in your values. Never commit .env files.

# ─── Contracts ───────────────────────────────────────────────────────────────
# Arc Testnet RPC (get from Circle developer portal)
ARC_TESTNET_RPC=https://rpc.arc-testnet.circle.com
ARC_CHAIN_ID=480

# Deployer private key (testnet only — never use a mainnet key here)
DEPLOYER_PRIVATE_KEY=0x...

# USDC contract address on Arc Testnet (get from Circle docs)
USDC_ADDRESS=0x...

# Additional resolver wallets for the oracle (optional — defaults to deployer)
RESOLVER_2=0x...
RESOLVER_3=0x...

# ─── AI Engine ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

DATABASE_URL=postgresql://predictx:password@localhost:5432/predictx
REDIS_URL=redis://localhost:6379

PORT=3001

# Deployed contract addresses (filled after `yarn deploy:testnet`)
FACTORY_ADDRESS=0x...
ORACLE_ADDRESS=0x...

# ─── Web App ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_ARC_RPC=https://rpc.arc-testnet.circle.com
NEXT_PUBLIC_ARC_CHAIN_ID=480
NEXT_PUBLIC_FACTORY_ADDRESS=0x...
NEXT_PUBLIC_ORACLE_ADDRESS=0x...
NEXT_PUBLIC_USDC_ADDRESS=0x...
